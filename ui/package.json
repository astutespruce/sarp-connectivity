{
	"name": "sarp-prioritization-tool",
	"description": "National Aquatic Barrier Inventory & Prioritization Tool",
	"version": "4.0.0",
	"date": "2/4/2026",
	"author": "Brendan C. Ward <bcward@astutespruce.com>",
	"license": "MIT",
	"private": false,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"predeploy": "npm run build",
		"deploy": "rm -rf /var/www/sarp-connectivity/* && cp -r public/* /var/www/sarp-connectivity"
	},
	"dependencies": {
