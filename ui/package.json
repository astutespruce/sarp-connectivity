		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/svelte-query": "^6.0.18",
		"@types/node": "^25",
		"@uwdata/flechette": "^2.3.0",
		"arquero": "^8.0.3",
		"bits-ui": "^2.15.5",
		"camelcase-keys": "^10.0.2",
